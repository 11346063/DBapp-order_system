DJANGO_SECRET_KEY=your-secret-key-here-generate-with-django-get-random-secret-key
DEBUG=True

# 多個 host 以逗號分隔，部署時改為實際域名，例如 example.com,www.example.com
ALLOWED_HOSTS=127.0.0.1,localhost

# 多個 origin 以逗號分隔（需含 scheme），部署時改為實際來源
CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://localhost

DB_ENGINE=django.db.backends.mysql
DB_NAME=order_system
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Google OAuth 2.0（至 Google Cloud Console 建立憑證後填入）
GOOGLE_OAUTH2_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH2_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH2_REDIRECT_URI=http://localhost:8000/oauth/google/callback/
